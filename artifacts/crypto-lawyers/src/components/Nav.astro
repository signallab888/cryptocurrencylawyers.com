---
const navLinks = [
  { label: "Find a Lawyer", href: "/lawyers" },
  { label: "Practice Areas", href: "/practice-areas" },
  { label: "Jurisdictions", href: "/jurisdictions" },
  { label: "Articles", href: "/articles" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-[#27272a] bg-[#0a0a0a]/95 backdrop-blur-sm">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <nav class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="CryptocurrencyLawyers.com home">
        <div class="flex h-8 w-8 items-center justify-center rounded bg-blue-800 text-white text-sm font-bold">
          CL
        </div>
        <span class="hidden sm:block font-semibold text-[#fafafa] tracking-tight">
          CryptocurrencyLawyers
          <span class="text-[#a1a1aa] font-normal">.com</span>
        </span>
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-1">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "px-3 py-2 rounded-md text-sm font-medium transition-colors",
                currentPath.startsWith(link.href)
                  ? "text-[#fafafa] bg-[#18181b]"
                  : "text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b]",
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <!-- CTA -->
      <div class="flex items-center gap-3">
        <a
          href="/find-a-lawyer"
          class="hidden sm:inline-flex items-center rounded-md bg-blue-800 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-blue-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-700"
        >
          Get Legal Help
        </a>
        <!-- Mobile menu button (static for now) -->
        <button
          class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b]"
          aria-label="Open menu"
          id="mobile-menu-btn"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu (progressive enhancement) -->
    <div class="hidden md:hidden" id="mobile-menu">
      <div class="space-y-1 pb-4">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="block px-3 py-2 rounded-md text-sm font-medium text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b]"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="/find-a-lawyer"
          class="block mt-2 text-center rounded-md bg-blue-800 px-4 py-2 text-sm font-medium text-white hover:bg-blue-900"
        >
          Get Legal Help
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
