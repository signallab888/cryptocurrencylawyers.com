---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import LeadFormIsland from "../components/islands/LeadFormIsland";
import { listSpecialties, listJurisdictions } from "../lib/api";

// Fetch options at build time to populate dropdowns in the island
const [{ data: specialties }, { data: jurisdictions }] = await Promise.all([
  listSpecialties(),
  listJurisdictions(),
]);

const siteUrl = "https://www.cryptocurrencylawyers.com";

const title = "Get Matched with a Crypto Lawyer | Free Consultation";
const description =
  "Connect with verified cryptocurrency attorneys in 24 hours. Describe your case, pick your jurisdiction and specialty, and we'll match you with the right lawyer — free.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Cryptocurrency Lawyer Matching",
  description,
  url: `${siteUrl}/find-a-lawyer`,
  provider: { "@type": "Organization", name: "CryptocurrencyLawyers.com", url: siteUrl },
  areaServed: "Worldwide",
  serviceType: "Legal Referral",
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/find-a-lawyer"
  jsonLd={[serviceSchema]}
>
  <!-- Turnstile script — loaded only on this page via head slot -->
  <script
    slot="head"
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>

  <!-- ── HERO ───────────────────────────────────────────────────────────── -->
  <section class="border-b border-border bg-bg-secondary">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-border bg-bg-primary px-3 py-1 text-xs font-medium text-text-secondary mb-5">
        Free matching — no obligation
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-text-primary max-w-2xl mx-auto leading-tight">
        Get Matched with a Crypto Lawyer in 24 Hours
      </h1>
      <p class="mt-4 text-text-secondary max-w-xl mx-auto">
        Tell us about your situation. We'll connect you with a verified specialist — no spam, no cold calls.
      </p>
    </div>
  </section>

  <!-- ── MAIN CONTENT ───────────────────────────────────────────────────── -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Form island (2/3) -->
      <div class="lg:col-span-2">
        <LeadFormIsland
          client:visible
          specialties={specialties}
          jurisdictions={jurisdictions}
        />
      </div>

      <!-- Sidebar (1/3) -->
      <aside class="space-y-6">
        <!-- How it works -->
        <div class="rounded-xl border border-border bg-bg-secondary p-6">
          <h2 class="font-semibold text-text-primary mb-5">How It Works</h2>
          <ol class="space-y-4">
            {[
              { n: "1", title: "Submit Your Request", body: "Tell us about your case, jurisdiction, and budget. Takes 2 minutes." },
              { n: "2", title: "We Find Your Match", body: "Our team reviews your request and identifies the best-fit attorneys from our verified network." },
              { n: "3", title: "Connect in 24 Hours", body: "You hear back within 24 hours with attorney introductions — free of charge." },
            ].map((step) => (
              <li class="flex gap-3">
                <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/20 text-accent-muted text-xs font-bold mt-0.5">
                  {step.n}
                </div>
                <div>
                  <p class="text-sm font-medium text-text-primary">{step.title}</p>
                  <p class="text-xs text-text-secondary mt-0.5">{step.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <!-- Trust signals -->
        <div class="rounded-xl border border-border bg-bg-secondary p-6 space-y-3">
          <h2 class="font-semibold text-text-primary mb-4">Why Use Us</h2>
          {[
            "100% free matching service",
            "Verified crypto attorneys only",
            "Response within 24 hours",
            "No cold calls or spam",
            "All specialties covered",
          ].map((item) => (
            <div class="flex items-center gap-2 text-sm text-text-secondary">
              <svg class="h-4 w-4 shrink-0 text-accent-bright" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {item}
            </div>
          ))}
        </div>

        <!-- Testimonial placeholder -->
        <div class="rounded-xl border border-border bg-bg-secondary p-6">
          <p class="text-sm text-text-secondary italic leading-relaxed">
            "Found the right SEC defense attorney within a day. The matching process was seamless and completely free."
          </p>
          <p class="mt-3 text-xs text-text-muted">— Founder, DeFi Protocol (name withheld)</p>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
