---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { adminGetLead, adminPatchLead, type LeadAdminItem } from "../../../lib/api";

// ── Clerk auth ────────────────────────────────────────────────────────────────
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const auth = (Astro.locals as any).auth?.();
const userId: string | null = auth?.userId ?? null;

if (!userId) {
  return Astro.redirect("/admin/sign-in");
}

const token: string = (await auth.getToken()) ?? "";
const { id: idParam } = Astro.params;
const id = Number(idParam);

if (!id || isNaN(id)) {
  return Astro.redirect("/admin/leads");
}

// ── Handle status update (POST form submission) ───────────────────────────────
let updateError: string | null = null;
let updateSuccess = false;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const newStatus = formData.get("status") as LeadAdminItem["status"];
    if (newStatus) {
      await adminPatchLead(token, id, newStatus);
      return Astro.redirect(`/admin/leads/${id}?updated=1`);
    }
  } catch (err) {
    updateError = err instanceof Error ? err.message : "Update failed";
  }
}

if (Astro.url.searchParams.get("updated") === "1") {
  updateSuccess = true;
}

// ── Fetch lead ────────────────────────────────────────────────────────────────
let lead: LeadAdminItem | null = null;
let fetchError: string | null = null;

try {
  lead = await adminGetLead(token, id);
} catch (err) {
  fetchError = err instanceof Error ? err.message : "Lead not found";
}

const STATUS_COLORS: Record<string, string> = {
  new: "bg-blue-900/30 text-blue-400",
  qualified: "bg-green-900/30 text-green-400",
  sold: "bg-purple-900/30 text-purple-400",
  closed: "bg-border/40 text-text-muted",
  spam: "bg-red-900/30 text-red-400",
};

const ALL_STATUSES: LeadAdminItem["status"][] = ["new", "qualified", "sold", "closed", "spam"];

const BUDGET_LABELS: Record<string, string> = {
  under_10k: "Under $10,000",
  "10k_50k": "$10,000 – $50,000",
  "50k_250k": "$50,000 – $250,000",
  "250k_plus": "$250,000+",
  unknown: "Not specified",
};

const URGENCY_LABELS: Record<string, string> = {
  immediate: "Immediate (days)",
  weeks: "Within a few weeks",
  planning: "Just planning ahead",
};
---

<BaseLayout
  title={lead ? `Lead #${id} — ${lead.clientName} | Admin` : `Lead #${id} | Admin`}
  description="Admin lead detail page."
  noIndex={true}
>
  <!-- Admin header -->
  <div class="border-b border-border bg-bg-secondary">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4 flex items-center gap-3">
      <a href="/admin/leads" class="text-xs text-text-muted hover:text-text-secondary">
        ← All Leads
      </a>
      <span class="text-border">|</span>
      <span class="text-sm font-semibold text-text-primary">Lead #{id}</span>
      {lead && (
        <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${STATUS_COLORS[lead.status] ?? ""}`}>
          {lead.status}
        </span>
      )}
    </div>
  </div>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-8">
    {updateSuccess && (
      <div class="mb-6 rounded-lg bg-green-900/20 border border-green-900/40 px-4 py-3 text-sm text-green-400">
        Lead status updated successfully.
      </div>
    )}

    {updateError && (
      <div class="mb-6 rounded-lg bg-red-900/20 border border-red-900/40 px-4 py-3 text-sm text-red-400">
        {updateError}
      </div>
    )}

    {fetchError ? (
      <div class="rounded-xl border border-red-900/40 bg-red-900/20 p-8 text-center">
        <p class="text-sm text-red-400">{fetchError}</p>
        <a href="/admin/leads" class="mt-3 inline-block text-sm text-accent-muted hover:text-accent-light underline">
          Back to Leads
        </a>
      </div>
    ) : lead ? (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Lead detail -->
        <div class="lg:col-span-2 space-y-6">

          <!-- Contact info -->
          <div class="rounded-xl border border-border bg-bg-secondary p-6">
            <h2 class="font-bold text-text-primary mb-4 text-sm">Contact Information</h2>
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
              <div>
                <dt class="text-text-muted text-xs mb-1">Name</dt>
                <dd class="text-text-primary font-medium">{lead.clientName}</dd>
              </div>
              <div>
                <dt class="text-text-muted text-xs mb-1">Email</dt>
                <dd>
                  <a href={`mailto:${lead.clientEmail}`} class="text-accent-muted hover:text-accent-light">
                    {lead.clientEmail}
                  </a>
                </dd>
              </div>
              {lead.clientPhone && (
                <div>
                  <dt class="text-text-muted text-xs mb-1">Phone</dt>
                  <dd>
                    <a href={`tel:${lead.clientPhone}`} class="text-text-primary">
                      {lead.clientPhone}
                    </a>
                  </dd>
                </div>
              )}
              <div>
                <dt class="text-text-muted text-xs mb-1">Submitted</dt>
                <dd class="text-text-secondary">
                  {new Date(lead.createdAt).toLocaleString("en-US", {
                    month: "long", day: "numeric", year: "numeric", hour: "2-digit", minute: "2-digit"
                  })}
                </dd>
              </div>
            </dl>
          </div>

          <!-- Case details -->
          <div class="rounded-xl border border-border bg-bg-secondary p-6">
            <h2 class="font-bold text-text-primary mb-4 text-sm">Case Details</h2>
            <dl class="space-y-3 text-sm">
              {lead.specialtyName && (
                <div class="flex justify-between">
                  <dt class="text-text-muted">Specialty</dt>
                  <dd class="text-text-primary font-medium">{lead.specialtyName}</dd>
                </div>
              )}
              {lead.jurisdictionName && (
                <div class="flex justify-between">
                  <dt class="text-text-muted">Jurisdiction</dt>
                  <dd class="text-text-primary font-medium">{lead.jurisdictionName}</dd>
                </div>
              )}
              <div class="flex justify-between">
                <dt class="text-text-muted">Budget</dt>
                <dd class="text-text-primary">{BUDGET_LABELS[lead.budgetRange] ?? lead.budgetRange}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-text-muted">Urgency</dt>
                <dd class="text-text-primary">{URGENCY_LABELS[lead.urgency] ?? lead.urgency}</dd>
              </div>
              {lead.captchaScore !== undefined && lead.captchaScore !== null && (
                <div class="flex justify-between">
                  <dt class="text-text-muted">Captcha score</dt>
                  <dd class="text-text-primary">{lead.captchaScore}</dd>
                </div>
              )}
            </dl>
            {lead.description && (
              <div class="mt-4 pt-4 border-t border-border">
                <p class="text-xs text-text-muted mb-2">Description</p>
                <p class="text-sm text-text-secondary leading-relaxed">{lead.description}</p>
              </div>
            )}
          </div>

          <!-- Tracking -->
          {(lead.sourcePage || lead.utmSource || lead.utmMedium || lead.utmCampaign) && (
            <div class="rounded-xl border border-border bg-bg-secondary p-6">
              <h2 class="font-bold text-text-primary mb-4 text-sm">Source Tracking</h2>
              <dl class="space-y-2 text-sm">
                {lead.sourcePage && (
                  <div>
                    <dt class="text-text-muted text-xs">Source page</dt>
                    <dd class="text-text-secondary text-xs break-all">{lead.sourcePage}</dd>
                  </div>
                )}
                {lead.utmSource && (
                  <div class="flex justify-between">
                    <dt class="text-text-muted">UTM source</dt>
                    <dd class="text-text-secondary">{lead.utmSource}</dd>
                  </div>
                )}
                {lead.utmMedium && (
                  <div class="flex justify-between">
                    <dt class="text-text-muted">UTM medium</dt>
                    <dd class="text-text-secondary">{lead.utmMedium}</dd>
                  </div>
                )}
                {lead.utmCampaign && (
                  <div class="flex justify-between">
                    <dt class="text-text-muted">UTM campaign</dt>
                    <dd class="text-text-secondary">{lead.utmCampaign}</dd>
                  </div>
                )}
              </dl>
            </div>
          )}
        </div>

        <!-- Actions sidebar -->
        <aside class="space-y-5">
          <!-- Status update -->
          <div class="rounded-xl border border-border bg-bg-secondary p-5">
            <h3 class="font-semibold text-text-primary text-sm mb-4">Update Status</h3>
            <form method="POST" class="space-y-3">
              <select
                name="status"
                class="w-full rounded-lg border border-border bg-bg-primary px-3 py-2 text-sm text-text-primary focus:border-accent focus:outline-none"
              >
                {ALL_STATUSES.map((s) => (
                  <option value={s} selected={lead?.status === s}>{s}</option>
                ))}
              </select>
              <button
                type="submit"
                class="w-full rounded-lg bg-accent py-2.5 text-sm font-semibold text-white hover:bg-accent-hover transition-colors"
              >
                Save Status
              </button>
            </form>

            <!-- Quick action buttons -->
            <div class="mt-3 grid grid-cols-2 gap-2">
              {(["qualified", "spam"] as const).filter((s) => s !== lead?.status).map((s) => (
                <form method="POST">
                  <input type="hidden" name="status" value={s} />
                  <button
                    type="submit"
                    class={`w-full rounded-lg border px-3 py-2 text-xs font-medium transition-colors ${
                      s === "spam"
                        ? "border-red-900/40 text-red-400 hover:bg-red-900/20"
                        : "border-green-900/40 text-green-400 hover:bg-green-900/20"
                    }`}
                  >
                    Mark {s}
                  </button>
                </form>
              ))}
            </div>
          </div>

          <!-- Lead metadata -->
          <div class="rounded-xl border border-border bg-bg-secondary p-5 text-xs space-y-2">
            <div class="flex justify-between">
              <span class="text-text-muted">Lead ID</span>
              <span class="text-text-secondary font-mono">#{lead.id}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-text-muted">Updated</span>
              <span class="text-text-secondary">
                {new Date(lead.updatedAt).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
              </span>
            </div>
          </div>
        </aside>
      </div>
    ) : null}
  </div>
</BaseLayout>
