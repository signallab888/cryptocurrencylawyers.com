---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { adminListLeads, type LeadAdminItem } from "../../../lib/api";

// ── Clerk auth ────────────────────────────────────────────────────────────────
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const auth = (Astro.locals as any).auth?.();
const userId: string | null = auth?.userId ?? null;

if (!userId) {
  return Astro.redirect("/admin/sign-in");
}

const token: string = (await auth.getToken()) ?? "";

// ── Query params ─────────────────────────────────────────────────────────────
const url = Astro.url;
const statusFilter = (url.searchParams.get("status") as LeadAdminItem["status"] | null) ?? undefined;
const page = Number(url.searchParams.get("page") ?? 1);

// ── Fetch leads ───────────────────────────────────────────────────────────────
let leads: LeadAdminItem[] = [];
let meta = { page: 1, pageSize: 50, total: 0, totalPages: 0 };
let fetchError: string | null = null;

try {
  const result = await adminListLeads(token, { status: statusFilter, page, pageSize: 50, sort: "createdAt", order: "desc" });
  leads = result.data;
  meta = result.meta;
} catch (err) {
  fetchError = err instanceof Error ? err.message : "Failed to load leads";
}

const STATUS_COLORS: Record<string, string> = {
  new: "bg-blue-900/30 text-blue-400",
  qualified: "bg-green-900/30 text-green-400",
  sold: "bg-purple-900/30 text-purple-400",
  closed: "bg-border/40 text-text-muted",
  spam: "bg-red-900/30 text-red-400",
};

const ALL_STATUSES: LeadAdminItem["status"][] = ["new", "qualified", "sold", "closed", "spam"];

const BUDGET_LABELS: Record<string, string> = {
  under_10k: "<$10k",
  "10k_50k": "$10–50k",
  "50k_250k": "$50–250k",
  "250k_plus": "$250k+",
  unknown: "Unknown",
};

const URGENCY_LABELS: Record<string, string> = {
  immediate: "Immediate",
  weeks: "Weeks",
  planning: "Planning",
};
---

<BaseLayout
  title="Leads Dashboard | Admin"
  description="Admin leads management dashboard."
  noIndex={true}
>
  <!-- Admin header -->
  <div class="border-b border-border bg-bg-secondary">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/" class="text-xs text-text-muted hover:text-text-secondary">
          ← Site
        </a>
        <span class="text-border">|</span>
        <span class="text-sm font-semibold text-text-primary">Admin / Leads</span>
      </div>
      <span class="text-xs text-text-muted">Signed in</span>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">

    <!-- Stats row -->
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-8">
      <a
        href="/admin/leads"
        class={`rounded-xl border p-4 text-center transition-colors hover:border-accent/40 ${!statusFilter ? "border-accent/40 bg-accent/10" : "border-border bg-bg-secondary"}`}
      >
        <div class="text-2xl font-bold text-text-primary">{meta.total}</div>
        <div class="text-xs text-text-muted mt-0.5">All</div>
      </a>
      {ALL_STATUSES.map((s) => (
        <a
          href={`/admin/leads?status=${s}`}
          class={`rounded-xl border p-4 text-center transition-colors hover:border-accent/40 ${statusFilter === s ? "border-accent/40 bg-accent/10" : "border-border bg-bg-secondary"}`}
        >
          <div class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium mb-1 ${STATUS_COLORS[s]}`}>
            {s}
          </div>
          <div class="text-xs text-text-muted">
            {statusFilter === s ? `${meta.total} shown` : ""}
          </div>
        </a>
      ))}
    </div>

    {fetchError ? (
      <div class="rounded-xl border border-red-900/40 bg-red-900/20 p-6 text-sm text-red-400">
        {fetchError}
      </div>
    ) : leads.length === 0 ? (
      <div class="rounded-xl border border-border bg-bg-secondary p-12 text-center">
        <p class="text-text-secondary text-sm">
          {statusFilter ? `No ${statusFilter} leads found.` : "No leads yet. They'll appear here after people submit the contact form."}
        </p>
        {statusFilter && (
          <a href="/admin/leads" class="mt-3 inline-block text-sm text-accent-muted hover:text-accent-light underline">
            Clear filter
          </a>
        )}
      </div>
    ) : (
      <>
        <div class="overflow-x-auto rounded-xl border border-border">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border bg-bg-secondary text-left">
                <th class="px-4 py-3 font-medium text-text-secondary">Name</th>
                <th class="px-4 py-3 font-medium text-text-secondary">Email</th>
                <th class="px-4 py-3 font-medium text-text-secondary">Specialty</th>
                <th class="px-4 py-3 font-medium text-text-secondary">Budget</th>
                <th class="px-4 py-3 font-medium text-text-secondary">Urgency</th>
                <th class="px-4 py-3 font-medium text-text-secondary">Status</th>
                <th class="px-4 py-3 font-medium text-text-secondary">Date</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              {leads.map((lead) => (
                <tr class="hover:bg-bg-secondary/60 transition-colors">
                  <td class="px-4 py-3">
                    <a href={`/admin/leads/${lead.id}`} class="font-medium text-text-primary hover:text-accent-muted">
                      {lead.clientName}
                    </a>
                    {lead.clientPhone && (
                      <div class="text-xs text-text-muted">{lead.clientPhone}</div>
                    )}
                  </td>
                  <td class="px-4 py-3 text-text-secondary">{lead.clientEmail}</td>
                  <td class="px-4 py-3 text-text-secondary text-xs">
                    {lead.specialtyName ?? "—"}
                    {lead.jurisdictionName && (
                      <div class="text-text-muted">{lead.jurisdictionName}</div>
                    )}
                  </td>
                  <td class="px-4 py-3 text-text-secondary text-xs">{BUDGET_LABELS[lead.budgetRange] ?? lead.budgetRange}</td>
                  <td class="px-4 py-3 text-text-secondary text-xs">{URGENCY_LABELS[lead.urgency] ?? lead.urgency}</td>
                  <td class="px-4 py-3">
                    <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${STATUS_COLORS[lead.status] ?? ""}`}>
                      {lead.status}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-text-muted text-xs">
                    {new Date(lead.createdAt).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {meta.totalPages > 1 && (
          <div class="mt-4 flex items-center justify-between text-sm">
            <span class="text-text-muted">
              Page {meta.page} of {meta.totalPages} ({meta.total} total)
            </span>
            <div class="flex gap-2">
              {meta.page > 1 && (
                <a href={`/admin/leads?${statusFilter ? `status=${statusFilter}&` : ""}page=${meta.page - 1}`}
                   class="rounded-lg border border-border px-3 py-1.5 text-xs text-text-secondary hover:bg-surface">
                  Previous
                </a>
              )}
              {meta.page < meta.totalPages && (
                <a href={`/admin/leads?${statusFilter ? `status=${statusFilter}&` : ""}page=${meta.page + 1}`}
                   class="rounded-lg border border-border px-3 py-1.5 text-xs text-text-secondary hover:bg-surface">
                  Next
                </a>
              )}
            </div>
          </div>
        )}
      </>
    )}
  </div>
</BaseLayout>
