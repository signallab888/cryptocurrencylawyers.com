---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

const hasClerk = !!import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY;
const afterSignIn = "/admin/leads";
---

<BaseLayout
  title="Admin Sign In | CryptocurrencyLawyers.com"
  description="Sign in to the CryptocurrencyLawyers admin panel."
  noIndex={true}
>
  <div class="flex min-h-[70vh] items-center justify-center px-4">
    {hasClerk ? (
      <div id="clerk-sign-in" />
      <script define:vars={{ afterSignIn }}>
        // Mount Clerk SignIn component via Clerk JS
        window.addEventListener("load", () => {
          if (window.Clerk) {
            window.Clerk.mountSignIn(document.getElementById("clerk-sign-in"), {
              afterSignInUrl: afterSignIn,
            });
          }
        });
      </script>
    ) : (
      <div class="max-w-sm w-full rounded-xl border border-border bg-bg-secondary p-8 text-center">
        <div class="mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-yellow-900/30">
          <svg class="h-6 w-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        </div>
        <h1 class="font-bold text-text-primary mb-2">Clerk Not Configured</h1>
        <p class="text-sm text-text-secondary mb-5">
          Set <code class="rounded bg-bg-primary px-1.5 py-0.5 text-xs text-accent-muted">PUBLIC_CLERK_PUBLISHABLE_KEY</code>
          and <code class="rounded bg-bg-primary px-1.5 py-0.5 text-xs text-accent-muted">CLERK_SECRET_KEY</code>
          in your <code class="rounded bg-bg-primary px-1.5 py-0.5 text-xs text-accent-muted">.env</code> file to enable the admin panel.
        </p>
        <a href="/" class="text-sm text-accent-muted hover:text-accent-light underline">Back to site</a>
      </div>
    )}
  </div>
</BaseLayout>
