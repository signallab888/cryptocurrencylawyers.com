---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { listArticles } from "../../lib/api";

const { data: articles, meta } = await listArticles({ pageSize: 50 });

const siteUrl = "https://www.cryptocurrencylawyers.com";

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Cryptocurrency Law Articles",
  url: `${siteUrl}/articles`,
  description: "Expert analysis and guides on cryptocurrency law, blockchain regulation, DeFi compliance, and digital asset litigation.",
  ...(articles.length > 0 ? {
    mainEntity: {
      "@type": "ItemList",
      numberOfItems: meta.total,
      itemListElement: articles.map((a, i) => ({
        "@type": "ListItem",
        position: i + 1,
        url: `${siteUrl}/articles/${a.slug}`,
        name: a.title,
      })),
    },
  } : {}),
};
---

<BaseLayout
  title="Cryptocurrency Law Articles & Guides | CryptocurrencyLawyers.com"
  description="Expert analysis on cryptocurrency law, blockchain regulation, DeFi compliance, NFT disputes, and digital asset taxation."
  canonical="/articles"
  jsonLd={[collectionSchema]}
>
  <div class="border-b border-border bg-bg-secondary">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
      <div class="inline-flex items-center gap-2 rounded-full border border-border bg-bg-primary px-3 py-1 text-xs font-medium text-text-secondary mb-4">
        Legal Resources
      </div>
      <h1 class="text-4xl font-bold text-text-primary">Crypto Law Articles</h1>
      <p class="mt-3 text-text-secondary max-w-xl">
        Expert guides and analysis on cryptocurrency law, blockchain regulation, and digital asset compliance.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    {articles.length === 0 ? (
      <div class="rounded-xl border border-border bg-bg-secondary p-16 text-center">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10">
          <svg class="h-6 w-6 text-accent-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <h2 class="font-semibold text-text-primary mb-2">Articles Coming Soon</h2>
        <p class="text-sm text-text-secondary max-w-sm mx-auto mb-6">
          Our team is preparing in-depth guides on cryptocurrency law. Check back soon.
        </p>
        <a href="/find-a-lawyer" class="inline-flex items-center rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-white hover:bg-accent-hover">
          Get Matched with a Lawyer
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map((article) => (
          <a
            href={`/articles/${article.slug}`}
            class="group flex flex-col rounded-xl border border-border bg-bg-secondary overflow-hidden transition-all hover:border-accent/40 hover:bg-surface-accent"
          >
            {article.featuredImageUrl && (
              <div class="aspect-video overflow-hidden bg-bg-primary">
                <img
                  src={article.featuredImageUrl}
                  alt={article.featuredImageAlt ?? article.title}
                  class="h-full w-full object-cover transition-transform group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            )}
            <div class="flex flex-col flex-1 p-5">
              <div class="mb-2 flex flex-wrap gap-1">
                {article.tags.slice(0, 2).map((tag) => (
                  <span class="rounded-full bg-accent/20 px-2 py-0.5 text-xs text-accent-muted">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="font-semibold text-text-primary group-hover:text-accent-muted line-clamp-2 text-sm leading-snug mb-2">
                {article.title}
              </h2>
              {article.excerpt && (
                <p class="text-xs text-text-secondary line-clamp-3 leading-relaxed flex-1">
                  {article.excerpt}
                </p>
              )}
              <div class="mt-4 flex items-center justify-between text-xs text-text-muted">
                <span>
                  {article.publishedAt
                    ? new Date(article.publishedAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
                    : ""}
                </span>
                {article.readingTimeMinutes && (
                  <span>{article.readingTimeMinutes} min read</span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
