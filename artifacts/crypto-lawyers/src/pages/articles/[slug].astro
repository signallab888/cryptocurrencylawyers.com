---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { listArticles, getArticleBySlug, type ArticleSummary } from "../../lib/api";

export async function getStaticPaths() {
  const { data } = await listArticles({ pageSize: 100 });
  return data.map((a) => ({
    params: { slug: a.slug },
    props: { slug: a.slug },
  }));
}

interface Props { slug: string }
const { slug } = Astro.props;

const article = await getArticleBySlug(slug);

// Related articles — same specialty or practice area (fetched in parallel if ids exist)
let related: ArticleSummary[] = [];
if (article.specialtyId || article.practiceAreaId) {
  const { data: rel } = await listArticles({
    ...(article.specialtyId ? { specialtySlug: "" } : {}), // fallback
    pageSize: 3,
  });
  related = rel.filter((a) => a.slug !== slug).slice(0, 3);
}

const siteUrl = "https://www.cryptocurrencylawyers.com";

const title = article.metaTitle ?? article.title;
const description = article.metaDescription ?? article.excerpt ?? `Read about ${article.title} on CryptocurrencyLawyers.com.`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, item: { "@id": siteUrl, name: "Home" } },
    { "@type": "ListItem", position: 2, item: { "@id": `${siteUrl}/articles`, name: "Articles" } },
    { "@type": "ListItem", position: 3, item: { "@id": `${siteUrl}/articles/${slug}`, name: article.title } },
  ],
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title,
  description: article.excerpt ?? undefined,
  ...(article.featuredImageUrl ? { image: article.featuredImageUrl } : {}),
  ...(article.authorName ? { author: { "@type": "Person", name: article.authorName } } : {}),
  publisher: { "@type": "Organization", name: "CryptocurrencyLawyers.com", url: siteUrl },
  datePublished: article.publishedAt ?? article.createdAt,
  dateModified: article.updatedAt,
  url: `${siteUrl}/articles/${slug}`,
  mainEntityOfPage: { "@type": "WebPage", "@id": `${siteUrl}/articles/${slug}` },
};
---

<BaseLayout
  title={`${title} | CryptocurrencyLawyers.com`}
  description={description}
  canonical={`/articles/${slug}`}
  ogImage={article.featuredImageUrl ?? undefined}
  jsonLd={[breadcrumbSchema, articleSchema]}
>
  <!-- BREADCRUMB -->
  <nav class="border-b border-border bg-bg-secondary" aria-label="Breadcrumb">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-text-secondary">
        <li><a href="/" class="hover:text-text-primary transition-colors">Home</a></li>
        <li class="text-border">/</li>
        <li><a href="/articles" class="hover:text-text-primary transition-colors">Articles</a></li>
        <li class="text-border">/</li>
        <li class="text-text-primary font-medium truncate max-w-xs">{article.title}</li>
      </ol>
    </div>
  </nav>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">

      <!-- Main article -->
      <article class="lg:col-span-3">
        <!-- Tags -->
        <div class="mb-4 flex flex-wrap gap-2">
          {article.tags.map((tag) => (
            <a
              href={`/articles?tag=${encodeURIComponent(tag)}`}
              class="rounded-full bg-accent/20 px-3 py-1 text-xs font-medium text-accent-muted hover:bg-accent/30 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>

        <!-- Headline -->
        <h1 class="text-3xl sm:text-4xl font-bold text-text-primary leading-tight mb-4">
          {article.title}
        </h1>

        <!-- Meta row -->
        <div class="flex flex-wrap items-center gap-4 text-xs text-text-muted mb-8 pb-6 border-b border-border">
          {article.authorName && <span>By {article.authorName}</span>}
          {article.publishedAt && (
            <span>
              {new Date(article.publishedAt).toLocaleDateString("en-US", {
                month: "long", day: "numeric", year: "numeric"
              })}
            </span>
          )}
          {article.readingTimeMinutes && (
            <span class="flex items-center gap-1">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
              </svg>
              {article.readingTimeMinutes} min read
            </span>
          )}
        </div>

        <!-- Featured image -->
        {article.featuredImageUrl && (
          <div class="mb-8 rounded-xl overflow-hidden border border-border">
            <img
              src={article.featuredImageUrl}
              alt={article.featuredImageAlt ?? article.title}
              class="w-full object-cover"
              loading="eager"
            />
          </div>
        )}

        <!-- Content -->
        <div
          class="prose prose-invert max-w-none text-text-secondary leading-relaxed"
          set:html={article.content}
        />

        <!-- CTA -->
        <div class="mt-12 rounded-xl border border-accent/30 bg-accent/10 p-6">
          <h3 class="font-bold text-text-primary mb-2">Need help with this?</h3>
          <p class="text-sm text-text-secondary mb-4">
            Connect with a verified cryptocurrency attorney who specializes in this area.
          </p>
          <a
            href="/find-a-lawyer"
            class="inline-flex items-center rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-white hover:bg-accent-hover transition-colors"
          >
            Find a Lawyer
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="sticky top-6 space-y-6">
          <!-- Quick match CTA -->
          <div class="rounded-xl border border-border bg-bg-secondary p-5">
            <h3 class="font-semibold text-text-primary text-sm mb-3">Get Legal Help</h3>
            <p class="text-xs text-text-secondary mb-4">Free matching with a verified crypto attorney in 24 hours.</p>
            <a href="/find-a-lawyer" class="block w-full rounded-lg bg-accent py-2.5 text-center text-sm font-semibold text-white hover:bg-accent-hover transition-colors">
              Get Matched
            </a>
          </div>

          <!-- Related articles -->
          {related.length > 0 && (
            <div class="rounded-xl border border-border bg-bg-secondary p-5">
              <h3 class="font-semibold text-text-primary text-sm mb-4">Related Articles</h3>
              <ul class="space-y-3">
                {related.map((r) => (
                  <li>
                    <a href={`/articles/${r.slug}`} class="text-xs text-text-secondary hover:text-accent-muted transition-colors line-clamp-2 leading-relaxed">
                      {r.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
