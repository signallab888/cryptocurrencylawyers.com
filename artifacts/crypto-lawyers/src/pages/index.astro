---
import BaseLayout from "../layouts/BaseLayout.astro";

const practiceAreas = [
  {
    name: "Regulatory & Compliance",
    slug: "regulatory-compliance",
    description: "SEC enforcement defense, exchange licensing, AML/KYC programs, OFAC sanctions compliance, and MiCA guidance.",
    icon: "shield",
  },
  {
    name: "Litigation & Enforcement",
    slug: "litigation-enforcement",
    description: "Crypto fraud recovery, asset tracing via blockchain forensics, class actions, and NFT dispute resolution.",
    icon: "scale",
  },
  {
    name: "Tax",
    slug: "tax",
    description: "Crypto tax returns, FBAR filings, voluntary disclosures, IRS audit defense, and Tax Court proceedings.",
    icon: "calculator",
  },
  {
    name: "Transactional",
    slug: "transactional",
    description: "Token launches, DAO formation, DeFi protocol counsel, mining operations, and cross-border transactions.",
    icon: "file",
  },
  {
    name: "Criminal Defense",
    slug: "criminal-defense",
    description: "Defense against money laundering charges, unlicensed money transmission, and federal crypto-related crimes.",
    icon: "shield-alert",
  },
  {
    name: "Estate Planning & Wealth",
    slug: "estate-planning",
    description: "Digital asset inheritance, crypto estate plans, key-management protocols, and divorce asset division.",
    icon: "book",
  },
  {
    name: "Intellectual Property",
    slug: "intellectual-property",
    description: "NFT copyright and trademark disputes, blockchain patent strategy, and smart contract IP issues.",
    icon: "lightbulb",
  },
];

const steps = [
  {
    number: "01",
    title: "Describe Your Case",
    body: "Tell us about your legal situation — jurisdiction, area of law, urgency, and budget range. Takes under 2 minutes.",
  },
  {
    number: "02",
    title: "Get Matched",
    body: "We surface verified attorneys whose practice, jurisdiction, and experience match your specific crypto legal need.",
  },
  {
    number: "03",
    title: "Consult Securely",
    body: "Connect directly with your matched attorney. Many offer free initial consultations and accept crypto payments.",
  },
];

const whyPoints = [
  {
    title: "They speak the language",
    body: "Crypto-specialist attorneys understand blockchain architecture, smart contracts, and DeFi — no educating them from scratch.",
  },
  {
    title: "Multi-jurisdictional expertise",
    body: "Crypto law spans SEC, CFTC, FinCEN, IRS, and international regulators. Specialists know which agency has jurisdiction.",
  },
  {
    title: "Up-to-date on regulation",
    body: "The regulatory landscape changes weekly. Specialist attorneys track enforcement trends, no-action letters, and case law.",
  },
  {
    title: "Protect your assets",
    body: "From wallet seizures to exchange bankruptcies — a specialist who has handled these exact scenarios saves time and money.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  name: "CryptocurrencyLawyers.com",
  description:
    "Directory of verified attorneys specializing in cryptocurrency, blockchain, DeFi, and digital asset law.",
  url: "https://www.cryptocurrencylawyers.com",
  serviceType: "Lawyer Directory",
  areaServed: "Worldwide",
};
---

<BaseLayout
  title="CryptocurrencyLawyers.com — Find a Crypto & Blockchain Lawyer"
  description="Find verified cryptocurrency lawyers specializing in blockchain regulation, SEC defense, DeFi, NFT disputes, crypto tax, and digital asset litigation. 50+ vetted attorneys across 51 jurisdictions."
  jsonLd={jsonLd}
>
  <!-- ── HERO ────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden">
    <!-- Subtle radial glow -->
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(30,64,175,0.25) 0%, transparent 70%);"
    >
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-20 pb-24 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-[#27272a] bg-[#111111] px-4 py-1.5 text-xs font-medium text-[#a1a1aa] mb-8">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        Verified attorneys · Updated weekly
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#fafafa] leading-tight tracking-tight max-w-4xl mx-auto">
        Find the Right
        <span class="text-blue-500"> Cryptocurrency Lawyer</span>
      </h1>

      <p class="mt-6 text-lg text-[#a1a1aa] max-w-2xl mx-auto leading-relaxed">
        Connect with attorneys who specialize in blockchain regulation, DeFi, SEC enforcement,
        crypto tax, and digital asset litigation — not generalists learning on your time.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/lawyers"
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-lg bg-blue-800 px-8 py-3.5 text-base font-semibold text-white transition-colors hover:bg-blue-900"
        >
          Browse Lawyers
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a
          href="/find-a-lawyer"
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-lg border border-[#27272a] bg-[#111111] px-8 py-3.5 text-base font-semibold text-[#fafafa] transition-colors hover:bg-[#18181b]"
        >
          Get Free Match
        </a>
      </div>

      <!-- Trust bar -->
      <div class="mt-14 flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-12 text-sm">
        <div class="flex items-center gap-2 text-[#a1a1aa]">
          <svg class="h-4 w-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span><strong class="text-[#fafafa]">50+</strong> Vetted Attorneys</span>
        </div>
        <div class="flex items-center gap-2 text-[#a1a1aa]">
          <svg class="h-4 w-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span><strong class="text-[#fafafa]">51</strong> Jurisdictions</span>
        </div>
        <div class="flex items-center gap-2 text-[#a1a1aa]">
          <svg class="h-4 w-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span><strong class="text-[#fafafa]">7</strong> Practice Areas</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PRACTICE AREAS ─────────────────────────────────────────────────── -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-[#fafafa]">Every Area of Crypto Law, Covered</h2>
      <p class="mt-3 text-[#a1a1aa]">
        Browse by the legal issue you're facing — every category has verified specialists.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        practiceAreas.map((area) => (
          <a
            href={`/practice-areas/${area.slug}`}
            class="group relative rounded-xl border border-[#27272a] bg-[#111111] p-6 transition-all hover:border-blue-800/60 hover:bg-[#111827]"
          >
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-blue-800/20 text-blue-400">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                {area.icon === "shield" && (
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                )}
                {area.icon === "scale" && (
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.97zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.59 1.202A5.989 5.989 0 015.25 16.5a5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.97z" />
                )}
                {area.icon === "calculator" && (
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25z" />
                )}
                {area.icon === "file" && (
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                )}
                {area.icon === "shield-alert" && (
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.249-8.25-3.286zm0 13.036h.008v.008H12v-.008z" />
                )}
                {area.icon === "book" && (
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                )}
                {area.icon === "lightbulb" && (
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
                )}
              </svg>
            </div>
            <h3 class="font-semibold text-[#fafafa] mb-2 group-hover:text-blue-400 transition-colors">
              {area.name}
            </h3>
            <p class="text-sm text-[#a1a1aa] leading-relaxed">{area.description}</p>
            <div class="mt-4 flex items-center text-xs font-medium text-blue-500">
              View lawyers
              <svg class="ml-1 h-3 w-3 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ── HOW IT WORKS ───────────────────────────────────────────────────── -->
  <section class="bg-[#111111] border-y border-[#27272a]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-[#fafafa]">How It Works</h2>
        <p class="mt-3 text-[#a1a1aa]">From describing your issue to your first consultation in minutes.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
        <!-- Connector line (desktop) -->
        <div class="hidden md:block absolute top-8 left-1/3 right-1/3 h-px bg-gradient-to-r from-transparent via-[#27272a] to-transparent"></div>

        {
          steps.map((step) => (
            <div class="flex flex-col items-center text-center">
              <div class="flex h-16 w-16 items-center justify-center rounded-full border-2 border-blue-800/40 bg-blue-800/10 text-2xl font-bold text-blue-400 mb-6">
                {step.number}
              </div>
              <h3 class="text-lg font-semibold text-[#fafafa] mb-2">{step.title}</h3>
              <p class="text-sm text-[#a1a1aa] leading-relaxed max-w-xs">{step.body}</p>
            </div>
          ))
        }
      </div>

      <div class="text-center mt-12">
        <a
          href="/find-a-lawyer"
          class="inline-flex items-center justify-center rounded-lg bg-blue-800 px-8 py-3.5 text-base font-semibold text-white transition-colors hover:bg-blue-900"
        >
          Start Your Match
        </a>
      </div>
    </div>
  </section>

  <!-- ── WHY SPECIALIST ─────────────────────────────────────────────────── -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl font-bold text-[#fafafa] leading-tight">
          Why a Crypto-Specialist?<br />
          <span class="text-[#a1a1aa] font-normal text-2xl">Not just any lawyer will do.</span>
        </h2>
        <p class="mt-4 text-[#a1a1aa] leading-relaxed">
          Cryptocurrency cases involve overlapping regulatory agencies, novel legal theories, and rapidly
          changing law. A generalist who handled your neighbor's DUI is not equipped for an SEC Wells Notice
          or a DeFi protocol enforcement action.
        </p>
        <a href="/lawyers" class="mt-8 inline-flex items-center text-sm font-medium text-blue-400 hover:text-blue-300">
          Browse the directory
          <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
          whyPoints.map((point) => (
            <div class="rounded-xl border border-[#27272a] bg-[#111111] p-5">
              <div class="mb-2 h-2 w-8 rounded-full bg-blue-800/60"></div>
              <h3 class="font-semibold text-[#fafafa] text-sm mb-1">{point.title}</h3>
              <p class="text-xs text-[#a1a1aa] leading-relaxed">{point.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── BOTTOM CTA ─────────────────────────────────────────────────────── -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-24">
    <div class="rounded-2xl border border-blue-800/40 bg-gradient-to-br from-blue-800/20 to-transparent p-10 text-center"
         style="background-image: radial-gradient(ellipse 100% 100% at 50% 100%, rgba(30,64,175,0.15) 0%, transparent 70%);">
      <h2 class="text-3xl font-bold text-[#fafafa] mb-4">
        Facing a Crypto Legal Issue?
      </h2>
      <p class="text-[#a1a1aa] max-w-xl mx-auto mb-8">
        Describe your situation and we'll match you with the right specialist — no spam,
        no obligation. Many attorneys offer free initial consultations.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/find-a-lawyer"
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-lg bg-blue-800 px-8 py-3.5 text-base font-semibold text-white transition-colors hover:bg-blue-900"
        >
          Get Free Match
        </a>
        <a
          href="/lawyers"
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-lg border border-[#27272a] px-8 py-3.5 text-base font-semibold text-[#fafafa] transition-colors hover:bg-[#111111]"
        >
          Browse Directory
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
